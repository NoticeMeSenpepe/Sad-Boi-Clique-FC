!.vscode/extensions.json
*.swp
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel/

# Scraper local artefacts
scraper/node_modules/
scraper/.env
scraper/.env.local
scraper/playwright-report/
scraper/test-results/
